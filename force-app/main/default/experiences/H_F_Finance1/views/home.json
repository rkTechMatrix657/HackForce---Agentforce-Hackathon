    }, {
      "componentAttributes" : {
        "richTextValue" : "<div id=\"our-plans\" style=\"background: #F6F8FB; padding: 0 20px 64px;\"><div style=\"max-width: 1080px; margin: -56px auto 0; background: #FFFFFF; border-radius: 24px; box-shadow: 0 24px 60px rgba(10,31,68,0.16); padding: 40px 32px; display: flex; justify-content: center; gap: 56px; flex-wrap: wrap; text-align: center; position: relative; z-index: 2;\"><div><p style=\"font-size: 34px; font-weight: 800; color: #0A1F44; margin: 0;\">50,000+</p><p style=\"font-size: 13px; color: #5B6B82; margin: 6px 0 0; text-transform: uppercase; letter-spacing: 0.05em;\">Families Protected</p></div><div><p style=\"font-size: 34px; font-weight: 800; color: #0A1F44; margin: 0;\">&#8377;500 Cr+</p><p style=\"font-size: 13px; color: #5B6B82; margin: 6px 0 0; text-transform: uppercase; letter-spacing: 0.05em;\">Claims Settled</p></div><div><p style=\"font-size: 34px; font-weight: 800; color: #0A1F44; margin: 0;\">98%</p><p style=\"font-size: 13px; color: #5B6B82; margin: 6px 0 0; text-transform: uppercase; letter-spacing: 0.05em;\">Claim Settlement Ratio</p></div><div><p style=\"font-size: 34px; font-weight: 800; color: #0A1F44; margin: 0;\">8</p><p style=\"font-size: 13px; color: #5B6B82; margin: 6px 0 0; text-transform: uppercase; letter-spacing: 0.05em;\">Insurance Plans</p></div></div></div>"
      },
      "componentName" : "forceCommunity:richTextInline",
      "id" : "f1a1b002-1111-4a11-9a11-111111110002",
      "renderPriority" : "NEUTRAL",
      "renditionMap" : { },
      "type" : "component"
    }, {
      "componentAttributes" : {
        "richTextValue" : "<div style=\"background: #FFFFFF; padding: 8px 24px 72px;\"><div style=\"max-width: 900px; margin: 0 auto; display: flex; justify-content: center; gap: 28px; flex-wrap: wrap;\"><div style=\"flex: 1 1 320px; background: #F6F8FB; border-radius: 20px; padding: 32px; box-shadow: 0 16px 36px rgba(0,112,210,0.08); border-top: 4px solid #0070D2;\"><p style=\"font-weight: 800; color: #0A1F44; font-size: 18px; margin: 0 0 10px;\">&#129658; Health Insurance</p><p style=\"color: #5B6B82; font-size: 14px; line-height: 1.7; margin: 0;\">Covers hospitalisation and medical costs so an illness or accident never becomes a financial crisis.</p></div><div style=\"flex: 1 1 320px; background: #F6F8FB; border-radius: 20px; padding: 32px; box-shadow: 0 16px 36px rgba(201,162,39,0.1); border-top: 4px solid #C9A227;\"><p style=\"font-weight: 800; color: #0A1F44; font-size: 18px; margin: 0 0 10px;\">&#128176; Life Insurance</p><p style=\"color: #5B6B82; font-size: 14px; line-height: 1.7; margin: 0;\">Provides a guaranteed payout to your family, or builds long-term savings, depending on the plan you choose.</p></div></div></div>"
      },
      "componentName" : "forceCommunity:richTextInline",
      "id" : "25cb2d07-aaab-451b-a1fe-b892e4d1e1cc",
      "renderPriority" : "NEUTRAL",
