    }, {
      "componentAttributes" : {
        "richTextValue" : "<div style=\"background: #FFFFFF; padding: 8px 24px 80px;\"><div style=\"display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; max-width: 1000px; margin: 0 auto;\"><div style=\"background: #FFFFFF; border: 1px solid rgba(10,31,68,0.06); border-radius: 20px; padding: 32px; max-width: 260px; text-align: center; box-shadow: 0 16px 36px rgba(10,31,68,0.07);\"><div style=\"width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg, #0A1F44, #0070D2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 22px;\">&#128222;</div><p style=\"font-weight: 700; color: #0A1F44; margin: 0 0 8px;\">Call Us</p><p style=\"color: #5B6B82; font-size: 14px; line-height: 1.6; margin: 0;\">1800-123-4567<br/>Mon&ndash;Sat, 9am&ndash;7pm</p></div><div style=\"background: #FFFFFF; border: 1px solid rgba(10,31,68,0.06); border-radius: 20px; padding: 32px; max-width: 260px; text-align: center; box-shadow: 0 16px 36px rgba(10,31,68,0.07);\"><div style=\"width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg, #0A1F44, #0070D2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 22px;\">&#9993;&#65039;</div><p style=\"font-weight: 700; color: #0A1F44; margin: 0 0 8px;\">Email Us</p><p style=\"color: #5B6B82; font-size: 14px; line-height: 1.6; margin: 0;\">support@hffinance.example<br/>We reply within 24 hours</p></div><div style=\"background: #FFFFFF; border: 1px solid rgba(10,31,68,0.06); border-radius: 20px; padding: 32px; max-width: 260px; text-align: center; box-shadow: 0 16px 36px rgba(10,31,68,0.07);\"><div style=\"width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg, #0A1F44, #0070D2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 22px;\">&#127968;</div><p style=\"font-weight: 700; color: #0A1F44; margin: 0 0 8px;\">Visit Us</p><p style=\"col